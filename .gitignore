# ----------------------------------------------------------------------------
# Qt / C++ Project .gitignore
# ----------------------------------------------------------------------------

# Temporary files
*~
*.autosave
*.orig
*.rej
.#*
*.*#
.DS_Store
.directory
Thumbs.db

# Compiled objects
*.o
*.obj
*.a
*.so
*.so.*
*.dll
*.exe
*.pdb
*.ilk
*.idb
*.lib
*.core

# Qt-generated files
*.moc
moc_*.cpp
ui_*.h
qrc_*.cpp
*.qrc.dep
*.qm
*.qmake.stash
*.qmake.cache

# QtCreator user/session files
*.pro.user*
*.qbs.user*
CMakeLists.txt.user*

# Build directories (IMPORTANT)
build*/
*/build*/
.debug/
.release/

# Visual Studio
*.sln
*.suo
*.vcproj
*vcproj.*.*.user
*.vcxproj
*vcxproj.*
*.ncb
*.sdf
*.opensdf

# MinGW
*.Debug
*.Release

# Python bytecode
*.pyc

# Misc
tags
core
!core/

# Qt Creator internal dirs
.qtcreator/
.backup*/

# deploy and backup folers and subfolders
/backup*/
*/backup*/
/deploy*/
*/deploy*/

